PORT=5001
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Обязательно: длинная случайная строка (минимум 32 символа)
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# URL клиента (для CORS и OAuth-редиректов)
CLIENT_URL=http://localhost:5173

# URL сервера (для OAuth callback-ов)
API_URL=http://localhost:5001

# Пароль дефолтного admin-аккаунта (сменить сразу после первого входа)
ADMIN_PASSWORD=change_me_on_first_run
