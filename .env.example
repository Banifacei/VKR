# =============================================================================
# LUMEO — Unified Environment Configuration
# =============================================================================
# Скопируй этот файл в .env и заполни своими значениями.
# Никогда не коммить .env в репозиторий!
# Быстрый старт: cp .env.example .env && nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# БАЗА ДАННЫХ (PostgreSQL) — обязательно
# -----------------------------------------------------------------------------
DB_NAME=lumeo
DB_USER=lumeo
DB_PASSWORD=change_me_strong_password
# Для Docker Compose: postgres (имя сервиса). Для локалки: localhost
DB_HOST=postgres
DB_PORT=5432

# -----------------------------------------------------------------------------
# СЕРВЕР (Node.js) — обязательно
# -----------------------------------------------------------------------------
PORT=5001

# Секрет для подписи JWT. Обязательно: случайная строка ≥ 32 символа.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_hex_string_at_least_32_chars

# Публичный URL сервера (используется в ссылках, OAuth callback и CORS).
# В Docker за nginx: https://ваш.домен или http://localhost
API_URL=http://localhost

# Пароль дефолтного admin-аккаунта (admin@lumeo.local).
# Используется ТОЛЬКО при первом запуске, если в БД ещё нет ни одного admin-а.
ADMIN_PASSWORD=change_me_admin_password

# -----------------------------------------------------------------------------
# КЛИЕНТ (React/Vite) — обязательно
# -----------------------------------------------------------------------------
# URL клиента — используется сервером для CORS и OAuth-редиректов.
CLIENT_URL=http://localhost

# Базовый путь API для axios на клиенте.
# Через nginx (рекомендуется): /api
# Для локальной разработки без Docker: http://localhost:5001/api
VITE_API_URL=/api

# -----------------------------------------------------------------------------
# ИИ-АССИСТЕНТ (опционально, без ключа работает в режиме FAQ)
# Управление через Admin Panel → Интеграции → ИИ-ассистент
#
# Основной: Google Gemini (бесплатно, без IP-ограничений)
# Ключ: https://aistudio.google.com/apikey → Create API Key
# GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Запасной: Groq API (llama-3.1-8b-instant)
# Ключ: https://console.groq.com → API Keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# SMTP — для сброса пароля и уведомлений (опционально)
# Если не задан — email-функции отключены, но платформа работает
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=noreply@ваш.домен
# SMTP_PASS=пароль_приложения
# SMTP_FROM=Lumeo <noreply@ваш.домен>

# -----------------------------------------------------------------------------
# OAuth 2.0 — Яндекс (опционально, включается в Admin Panel → Настройки)
# Зарегистрировать приложение: https://oauth.yandex.ru
# Callback URL: https://ваш.домен/api/auth/yandex/callback
# -----------------------------------------------------------------------------
# YANDEX_CLIENT_ID=ваш_client_id
# YANDEX_CLIENT_SECRET=ваш_client_secret

# -----------------------------------------------------------------------------
# OAuth 2.0 — Google (опционально, включается в Admin Panel → Настройки)
# Зарегистрировать: https://console.cloud.google.com/apis/credentials
# Callback URL: https://ваш.домен/api/auth/google/callback
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=ваш_client_id
# GOOGLE_CLIENT_SECRET=ваш_client_secret

# -----------------------------------------------------------------------------
# SAML SSO (опционально, для корпоративной интеграции)
# Metadata IdP берётся из Admin Panel → Настройки → SAML
# -----------------------------------------------------------------------------
# SAML_CALLBACK_URL=https://ваш.домен/api/auth/saml/callback
# SAML_ISSUER=lumeo
# SAML_IDP_SSO_URL=https://idp.ваш.домен/sso
# SAML_IDP_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# -----------------------------------------------------------------------------
# LDAP / Active Directory (опционально)
# Настраивается через Admin Panel → Настройки → LDAP
# -----------------------------------------------------------------------------
# LDAP_URL=ldap://dc.ваш.домен:389
# LDAP_BIND_DN=CN=lumeo-svc,OU=ServiceAccounts,DC=ваш,DC=домен
# LDAP_BIND_CREDENTIALS=пароль_сервисного_аккаунта
# LDAP_SEARCH_BASE=OU=Users,DC=ваш,DC=домен
# LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
